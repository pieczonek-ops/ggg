// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: articles
// Document ID: auto-generated
// Fields:
//   - title: string (required) - The title of the article.
//   - slug: string (required) - URL-friendly version of the title.
//   - content: string (required) - The markdown content.
//   - excerpt: string (optional) - A short summary.
//   - category: string (required) - games, movies, or series.
//   - authorName: string (required) - The display name of the author.
//   - authorUid: string (required) - The Firebase Auth UID of the author.
//   - imageUrl: string (optional) - URL of the cover image.
//   - createdAt: timestamp (required) - When the article was published.
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "pieczonek@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.slug is string && data.slug.size() > 0 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.category in ['games', 'movies', 'series'] &&
             data.authorName is string && data.authorName.size() > 0 &&
             data.authorUid == request.auth.uid;
    }

    match /articles/{articleId} {
      // Anyone can read articles
      allow read: if true;
      
      // Only authenticated users can create articles
      allow create: if isAuthenticated() && isValidArticle(request.resource.data);
      
      // Only the author or an admin can update/delete articles
      allow update: if isAuthenticated() && 
                    (isOwner(resource.data.authorUid) || isAdmin()) && 
                    isValidArticle(request.resource.data);
      
      allow delete: if isAuthenticated() && (isOwner(resource.data.authorUid) || isAdmin());
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
  }
}
